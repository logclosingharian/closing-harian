const SPREADSHEET_ID = '1R9qYbz9Cvh6lgZw_eK7HtVJSQ7Q1p_Ita6NHc45hkv8';
const SHEETS = {
  Absensi      : ['Tanggal','Jam','Nama','Tipe','Status','Keterangan','Lokasi','Cabang'],
  Reimburse    : ['Tgl Ajukan','Nama','Jenis','Nominal','Tgl Pengeluaran','Keterangan','Status','Cabang'],
  DanaDarurat  : ['Tgl Ajukan','Nama','Alasan','Nominal','Cicilan/Bln','Keterangan','Status','Cabang'],
  SelisihKas   : ['Bulan','Nama','Selisih','Status','Cabang'],
  BonusTantangan:['Tanggal','Nama','Tantangan','Reward','Periode','Cabang'],
  _test        : ['Ping','Tanggal','Cabang'],
};

function doPost(e) {
  try {
    const data = JSON.parse(e.postData.contents);
    const ss   = SpreadsheetApp.openById(SPREADSHEET_ID);
    let sheet  = ss.getSheetByName(data.sheet);
    if (!sheet) {
      sheet = ss.insertSheet(data.sheet);
      const headers = SHEETS[data.sheet];
      if (headers) sheet.appendRow(headers);
    }
    (data.rows || []).forEach(row => sheet.appendRow(row));
    return ContentService.createTextOutput(JSON.stringify({status:'ok'}))
      .setMimeType(ContentService.MimeType.JSON);
  } catch(err) {
    return ContentService.createTextOutput(JSON.stringify({status:'error',msg:err.toString()}))
      .setMimeType(ContentService.MimeType.JSON);
  }
}

